# Copy this file to project root as .env on the live server.
# Do not commit real production secrets.

NODE_ENV=production
PORT=3000
APP_URL=https://your-domain.com

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=school_system
DB_USER=school_user
DB_PASSWORD=change_this_mysql_password

# Auth
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRE=30d
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_admin_password
PRINCIPAL_USERNAME=principal@school.com
PRINCIPAL_PASSWORD=change_this_principal_password

# Email SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=Kids Roots Jand
ADMIN_RECOVERY_EMAIL=your-email@gmail.com

# Reminders
PENDING_FEE_REMINDER_ENABLED=true
PENDING_FEE_REMINDER_TIME=09:00
PENDING_FEE_REMINDER_TIMEZONE=Asia/Karachi
PENDING_FEE_REMINDER_RUN_ON_START=true

# Optional security/origin values
CORS_ORIGIN=https://your-domain.com
FRONTEND_URL=https://your-domain.com
ALLOWED_ORIGIN_1=https://your-domain.com
ALLOWED_ORIGIN_2=

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

